# Server
APP_PORT=8080
APP_ENV=development

# Database PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=sso_pelajarnu

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_ACCESS_EXPIRE=3600      # 1 jam (dalam detik)
JWT_REFRESH_EXPIRE=604800   # 7 hari (dalam detik)

# App
APP_NAME=SSO IPNU-IPPNU Magetan
APP_URL=https://sso.pelajarnumagetan.or.id
API_URL=https://api.pelajarnumagetan.or.id

# Avatar Encryption (AES-256 — generate: openssl rand -hex 32)
AVATAR_KEY=your-32-byte-hex-key-here
